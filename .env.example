# ===========================================
# SIPMB UNISAN — Environment Variables
# File template untuk referensi deploy.
# Copy ke .env di server, lalu isi nilai aktual.
# ===========================================

# --- Django Core ---
SECRET_KEY=ubah-ke-random-string-minimal-50-karakter
DEBUG=False
ALLOWED_HOSTS=pmb.unisan-g.id,localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DB_NAME=unisan_db
DB_USER=unisan_user
DB_PASSWORD=ubah-password-db
DB_HOST=localhost
DB_PORT=5432

# --- External APIs ---
ANTHROPIC_API_KEY=sk-ant-...
FONNTE_TOKEN=token-fonnte-kamu
WHATSAPP_PMB=628xxxxxxxxxx

# --- Email (Gmail SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=pmb@unisan-g.id
EMAIL_HOST_PASSWORD=app-password-gmail-16-karakter
DEFAULT_FROM_EMAIL=PMB UNISAN <pmb@unisan-g.id>

# --- Duitku Payment Gateway (BELUM AKTIF) ---
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_SANDBOX=True

# --- SSO ---
SSO_BASE_URL=https://sso.unisan-g.id
SSO_CLIENT_ID=sipmb
SSO_CLIENT_SECRET=ubah-client-secret

# --- URL Base ---
BASE_URL=https://pmb.unisan-g.id